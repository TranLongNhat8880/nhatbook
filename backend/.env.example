# ── Cấu hình Server ───────────────────────────────────
PORT=3000

# ── Cấu hình Database (PostgreSQL - Render) ────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nhatbook
DB_USER=postgres
DB_PASSWORD=your_password

# Link Database URL đầy đủ (Dùng cho Render)
# DATABASE_URL=postgres://user:password@host:port/dbname

# ── Cấu hình Bảo mật ──────────────────────────────────
JWT_SECRET=thay_bang_mot_chuoi_ky_tu_bi_mat_va_dai

# ── Cấu hình Cloudinary (Quản lý ảnh) ──────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Cấu hình Frontend (Link web của bạn) ──────────────
# Với Cách B, FRONTEND_URL có thể để trống hoặc điền URL Render
FRONTEND_URL=
